# Shopio environment variables — example for local dev
# Copy to `.env` and fill in real values

# ---- Core
NODE_ENV=development
LOG_LEVEL=debug
PORT=4040
HOST=0.0.0.0

# ---- URLs (Shopio-specific port range to avoid conflicts with other local projects)
SHOPIO_BASE_URL=http://localhost:3030
SHOPIO_ADMIN_URL=http://localhost:3031
SHOPIO_API_URL=http://localhost:4040

# ---- Database (host port 5435; container 5432)
DATABASE_URL=postgres://shopio:shopio_dev_password@localhost:5435/shopio_dev

# ---- Redis (host port 6385; container 6379)
REDIS_URL=redis://localhost:6385/0
REDIS_BULLMQ_URL=redis://localhost:6385/1

# ---- Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev_master_key_change_in_production

# ---- Object storage (MinIO local; host port 9100; console 9101)
SHOPIO_S3_ENDPOINT=http://localhost:9100
SHOPIO_S3_REGION=us-east-1
SHOPIO_S3_ACCESS_KEY=minioadmin
SHOPIO_S3_SECRET_KEY=minioadmin
SHOPIO_S3_BUCKET_MEDIA=shopio-dev-media
SHOPIO_S3_USE_SSL=false

# ---- Email (Mailpit local; host port 1027 → container 1025)
# Web UI: http://localhost:8027
SMTP_HOST=localhost
SMTP_PORT=1027
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Shopio Dev <hello@shopio.local>

# ---- Secrets (DEV ONLY — generate strong random for production)
SHOPIO_JWT_SECRET=dev_jwt_secret_change_in_production_minimum_64_chars_long_please
SHOPIO_SESSION_PEPPER=dev_pepper_change_in_production_32_chars_min
SHOPIO_KMS_PROVIDER=local_dev

# ---- AI providers (per `33-ai-features.md`)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SHOPIO_AI_DEFAULT_PROVIDER=anthropic
SHOPIO_AI_FALLBACK_PROVIDER=openai

# ---- Payment providers (test mode)
# Leave blank or short placeholders to run in mock mode (order placed as pending_payment).
# Real keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: run `stripe listen --forward-to localhost:4040/api/2026-05-20/webhooks/stripe`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ---- Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=shopio
SENTRY_DSN=

# ---- CORS
CORS_ORIGIN=http://localhost:3030,http://localhost:3031

# Platform operator allowlist (cross-tenant master-admin). Comma-separated emails.
PLATFORM_ADMIN_EMAILS=admin-test@example.com

# Storefront: platform host(s) that should NOT be treated as a custom domain.
NEXT_PUBLIC_PLATFORM_HOSTS=localhost:3030,localhost
