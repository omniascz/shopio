# Shopio production environment — copy to .env.prod and fill the secrets.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Secrets (REQUIRED — generate long random values) -------------------------
POSTGRES_PASSWORD=
SHOPIO_JWT_SECRET=
SHOPIO_SESSION_PEPPER=
MEILI_MASTER_KEY=
MINIO_ROOT_USER=shopio-media
MINIO_ROOT_PASSWORD=

# --- RLS app role (per `30-security.md`, migration 0020) -----------------------
# Optional but RECOMMENDED. Connect the app as the non-superuser `shopio_app`
# role so Postgres Row-Level Security enforces tenant isolation. After first
# migrate, rotate the role password:  ALTER ROLE shopio_app PASSWORD '...';
# then set DATABASE_URL_APP. If unset, the app falls back to the superuser
# connection and RLS stays dormant (explicit tenant filters remain the guard).
# DATABASE_URL_APP=postgres://shopio_app:CHANGEME@postgres:5432/shopio

# --- Public URLs (what browsers see) ------------------------------------------
SHOPIO_BASE_URL=https://shop.example.com
SHOPIO_ADMIN_URL=https://admin.example.com
SHOPIO_API_URL=https://api.example.com
S3_PUBLIC_URL=https://media.example.com/shopio-media

# --- Ports (host bindings; front with a TLS proxy) -----------------------------
API_PORT=4040
STOREFRONT_PORT=3030
ADMIN_PORT=3031
MINIO_PORT=9100

# --- Mail (production SMTP relay) ----------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Můj obchod <noreply@example.com>
SMTP_ENABLED=true

# --- AI features (optional — per `33`; absent → deterministic mock) ------------
# Anthropic API key for AI product copy + SEO. Without it the admin "Generate"
# actions return a deterministic stub (mock:true). Real keys start "sk-ant-".
ANTHROPIC_API_KEY=

# --- Payments / carriers (optional until configured) ---------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PACKETA_API_KEY=
PACKETA_API_PASSWORD=

# Platform operator allowlist (cross-tenant master-admin). Comma-separated emails.
PLATFORM_ADMIN_EMAILS=
