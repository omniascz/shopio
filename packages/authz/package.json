{
  "name": "@shopio/authz",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shopio authorization: permission catalog, persona definitions, ABAC policy engine",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./permissions": "./src/permissions.ts",
    "./personas": "./src/personas.ts",
    "./password": "./src/password.ts",
    "./tokens": "./src/tokens.ts",
    "./sessions": "./src/sessions.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.0",
    "jose": "^5.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
