{
  "name": "@shopio/authz",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shopio authorization: permission catalog, persona definitions, ABAC policy engine",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./permissions": "./src/permissions.ts",
    "./personas": "./src/personas.ts",
    "./policies": "./src/policies/index.ts"
  },
  "scripts": {
