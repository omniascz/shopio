{
  "name": "@shopio/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shopio database schema, migrations, and Drizzle ORM client",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "migrate": "tsx src/migrate.ts",
    "migrate:drizzle": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed/index.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@shopio/authz": "workspace:*",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
