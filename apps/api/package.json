{
  "name": "@shopio/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shopio API gateway — Fastify (per DEC-ARCH-005)",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.0",
    "@shopio/authz": "workspace:*",
    "@shopio/db": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "meilisearch": "^0.58.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "stripe": "^22.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
