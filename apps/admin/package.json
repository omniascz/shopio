{
  "name": "@shopio/admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shopio admin — Vite + React 19 SPA (per DEC-FE-001)",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite --port 3031",
